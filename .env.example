# =============================================================
# DESIGN SYSTEM ACCESS PASSWORD
# =============================================================
#
# Variable name : DESIGN_SYSTEM_PASSWORD
# Used by       : pages/api/design-system-login.js
# Protected path: /PS-Design/DesignSystemDocumentation/
#
# WHERE TO SET THE REAL PASSWORD
# ──────────────────────────────
# Production:
#   Vercel → Project → Settings → Environment Variables
#   Add DESIGN_SYSTEM_PASSWORD with your chosen password.
#   After saving, redeploy for the change to take effect.
#
# Local development:
#   Copy this file to .env.local and fill in a test value:
#     cp .env.example .env.local
#   .env.local is gitignored — never commit it.
#
# IMPORTANT
# ──────────────────────────────
# - Never add the real password here.
# - Never use the NEXT_PUBLIC_ prefix (exposes it to the browser).
# - Never commit .env.local.
# - Full guide: docs/design-system-access.md
#
# =============================================================

DESIGN_SYSTEM_PASSWORD=
