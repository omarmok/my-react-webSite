      "states": {
        "focus": {
          "outerRing": "rgba({color.primary.700}, 0.35) via --moi-focus-outer",
          "innerRing": "rgba({color.primary.700}, 0.75) via --moi-focus-inner",
          "outline": "2px solid currentColor"
        },
        "disabled": {
          "background": "{color.neutral.100}",
          "border": "{color.neutral.300}",
          "text": "{color.neutral.400}",
          "cursor": "not-allowed"
        }
      },
      "notes": [
        "Lavender, Warning and Error tokens mirror the Primary and Neutral patterns (solid/outline) but swap color.* scales.",
        "Icon-only buttons drop horizontal padding but maintain the height and radius tokens from buttons.size.<size>.",
        "Active state opacity (0.8) and focus ring opacity (rgba overlays) currently hardcoded and should become dedicated shadow/opacity tokens."
      ]
    },
    {
      "name": "Input Field",
      "anatomy": [
        "Label",
        "Input / textarea (.form-control)",
        "Helper text (e.g. .wanted-to or .form-group-info)",
        "Prefix / suffix icons and text (icons + .input-group-text)"
      ],
      "variants": [
        {
          "name": "Sizes",
          "tokens": {
            "default": "{forms.input.size.default}",
            "sm": "{forms.input.size.sm}",
            "md": "{forms.input.size.md}",
            "lg": "{forms.input.size.lg}",
            "xl": "{forms.input.size.xl}"
          }
        }
      ],
      "states": {
        "default": {
          "background": "{color.base.white}",
          "border": "{color.neutral.400}",
          "text": "{color.neutral.900}",
          "placeholder": "{color.neutral.500}",
          "transition": "border-color 0.3s, box-shadow 0.3s"
        },
        "focus": {
          "border": "{color.primary.500}",
          "boxShadow": "0 0 0 2px rgba({color.primary.500}, 0.12) (needs tokenized opacity)"
        },
        "disabled": {
          "background": "{color.neutral.50}",
          "border": "{color.neutral.200}",
          "text": "{color.neutral.500}",
          "cursor": "not-allowed"
        }
      },
      "notes": [
        "Helper text uses typography.mixins (meduimfont) so rely on typography.fontSize.sm + fontWeight.600.",
        "Select2 dropdown items reuse form-control padding but still rely on hard-coded border colors (#bababa).",
        "Textarea height is hard-coded (150px) and might benefit from spacing tokens if reused."
      ]
    },
    {
      "name": "Alert",
