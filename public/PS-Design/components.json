  "missingComponents": [
    {
      "name": "Chip",
      "reason": "No dedicated SCSS component (only priority badges). Recommend introducing a token-bound chip class for reusable pill states."
    },
    {
      "name": "Card",
      "reason": "Card styles are scattered across page-specific SCSS (cards in dashboard, landing, etc.) with raw colors; centralize a card component tied to color.neutral and shadow tokens."
    }
